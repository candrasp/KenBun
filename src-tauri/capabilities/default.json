{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Default capability for the Ken app",
  "windows": [
    "main",
    "log-window"
  ],
  "permissions": [
    "core:default",
    "start-bun",
    "stop-bun",
    "allow-open-browser",
    "allow-open-log-window",
    "allow-get-log-history",
    "core:tray:default",
    "core:menu:default",
    "opener:default"
  ]
}